function fluent:Notify(config)
	config = config or {}
	local title = config.Title or "Notification"
	local content = config.Content or ""
	local duration = config.Duration or 3
	
	local NotificationHolder = Create("Frame", {
		Name = "NotificationHolder",
		Parent = ScreenGui,
		Size = UDim2.new(0, 300, 1, 0),
		Position = UDim2.new(1, -310, 0, 10),
		BackgroundTransparency = 1
	}, {
		Create("UIListLayout", {
			SortOrder = Enum.SortOrder.LayoutOrder,
			Padding = UDim.new(0, 8),
			VerticalAlignment = Enum.VerticalAlignment.Top
		})
	})
	
	local Notification = Create("Frame", {
		Name = "Notification",
		Parent = NotificationHolder,
		Size = UDim2.new(1, 0, 0, 60),
		Position = UDim2.new(0, 0, 1, 0),
		BackgroundColor3 = GetThemeColor("Surface"),
		BorderSizePixel = 0
	})
	
	CreateCorner(Notification, 4)
	CreateStroke(Notification, GetThemeColor("Border"), 1)
	
	local TitleText = Create("TextLabel", {
		Parent = Notification,
		Size = UDim2.new(1, -24, 0, 20),
		Position = UDim2.new(0, 12, 0, 8),
		BackgroundTransparency = 1,
		Text = title,
		Font = Settings.FontBold,
		TextSize = 14,
		TextColor3 = Settings.AccentColor,
		TextXAlignment = Enum.TextXAlignment.Left
	})
	
	local ContentText = Create("TextLabel", {
		Parent = Notification,
		Size = UDim2.new(1, -24, 0, 20),
		Position = UDim2.new(0, 12, 0, 28),
		BackgroundTransparency = 1,
		Text = content,
		Font = Settings.Font,
		TextSize = 12,
		TextColor3 = GetThemeColor("TextSecondary"),
		TextXAlignment = Enum.TextXAlignment.Left,
		TextWrapped = true
	})
	
	Notification.Position = UDim2.new(1, 0, 0, 0)
	Tween(Notification, {Position = UDim2.new(0, 0, 0, 0)}, 0.3)
	
	task.wait(duration)
	
	Tween(Notification, {Position = UDim2.new(1, 0, 0, 0)}, 0.3)
	task.wait(0.3)
	Notification:Destroy()
	
	if #NotificationHolder:GetChildren() == 0 then
		NotificationHolder:Destroy()
	end
end

