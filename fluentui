			local Header = Create("Frame", {
				Parent = DropdownFrame,
				Size = UDim2.new(1, 0, 0, 40),
				BackgroundTransparency = 1
			})
			
			local DropdownText = Create("TextLabel", {
				Parent = Header,
				Size = UDim2.new(1, -70, 1, 0),
				Position = UDim2.new(0, 12, 0, 0),
				BackgroundTransparency = 1,
				Text = name,
				Font = Settings.FontMedium,
				TextSize = 14,
				TextColor3 = GetThemeColor("Text"),
				TextXAlignment = Enum.TextXAlignment.Left
			})
			
			if description then
				Create("TextLabel", {
					Parent = Header,
					Size = UDim2.new(1, -70, 1, 0),
					Position = UDim2.new(0, 12, 0, 0),
					BackgroundTransparency = 1,
					Text = description,
					Font = Settings.Font,
					TextSize = 12,
					TextColor3 = GetThemeColor("TextSecondary"),
					TextXAlignment = Enum.TextXAlignment.Left,
					TextYAlignment = Enum.TextYAlignment.Bottom
				})
			end
			
			local SelectedLabel = Create("TextLabel", {
				Parent = Header,
				Size = UDim2.new(0, 80, 1, 0),
				Position = UDim2.new(1, -100, 0, 0),
				BackgroundTransparency = 1,
				Text = tostring(selected),
				Font = Settings.Font,
				TextSize = 14,
				TextColor3 = Settings.AccentColor,
				TextXAlignment = Enum.TextXAlignment.Right
			})
			
			local Arrow = Create("ImageLabel", {
				Parent = Header,
				Size = UDim2.new(0, 16, 0, 16),
				Position = UDim2.new(1, -28, 0.5, -8),
				BackgroundTransparency = 1,
				Image = "rbxassetid://10709790948",
				ImageColor3 = GetThemeColor("TextSecondary")
			})
			
			local DropdownContent = Create("Frame", {
				Parent = DropdownFrame,
				Size = UDim2.new(1, 0, 0, 0),
				Position = UDim2.new(0, 0, 0, 40),
				BackgroundTransparency = 1,
				AutomaticSize = Enum.AutomaticSize.Y,
				Visible = false
			}, {
				Create("UIPadding", {
					PaddingLeft = UDim.new(0, 8),
					PaddingRight = UDim.new(0, 8),
					PaddingBottom = UDim.new(0, 8)
				}),
				Create("UIListLayout", {
					SortOrder = Enum.SortOrder.LayoutOrder,
					Padding = UDim.new(0, 4)
				})
			})
			
			local Button = Create("TextButton", {
				Parent = Header,
				Size = UDim2.new(1, 0, 1, 0),
				BackgroundTransparency = 1,
				Text = ""
			})
			
			-- Create option buttons
			for _, option in ipairs(options) do
				local OptionBtn = Create("TextButton", {
					Parent = DropdownContent,
					Size = UDim2.new(1, 0, 0, 28),
					BackgroundColor3 = GetThemeColor("Secondary"),
					Text = "",
					AutoButtonColor = false,
					BorderSizePixel = 0
				})
				
				CreateCorner(OptionBtn, 4)
				
				local OptionText = Create("TextLabel", {
					Parent = OptionBtn,
					Size = UDim2.new(1, -16, 1, 0),
					Position = UDim2.new(0, 8, 0, 0),
					BackgroundTransparency = 1,
					Text = tostring(option),
					Font = Settings.Font,
					TextSize = 14,
					TextColor3 = GetThemeColor("Text"),
					TextXAlignment = Enum.TextXAlignment.Left
				})
				
				if option == selected then
					OptionText.TextColor3 = Settings.AccentColor
				end
				
				OptionBtn.MouseButton1Click:Connect(function()
					selected = option
					SelectedLabel.Text = tostring(selected)
					callback(selected)
					
					for _, child in ipairs(DropdownContent:GetChildren()) do
						if child:IsA("TextButton") and child.TextLabel then
							child.TextLabel.TextColor3 = GetThemeColor("Text")
						end
					end
					OptionText.TextColor3 = Settings.AccentColor
					
					expanded = false
					Tween(DropdownFrame, {Size = UDim2.new(1, 0, 0, 40)}, 0.2)
					Tween(Arrow, {Rotation = 0}, 0.2)
					DropdownContent.Visible = false
				end)
				
				OptionBtn.MouseEnter:Connect(function()
					Tween(OptionBtn, {BackgroundColor3 = GetThemeColor("Surface")}, 0.1)
				end)
				
				OptionBtn.MouseLeave:Connect(function()
					Tween(OptionBtn, {BackgroundColor3 = GetThemeColor("Secondary")}, 0.1)
				end)
			end
			
			Button.MouseButton1Click:Connect(function()
				expanded = not expanded
				
				if expanded then
					local contentHeight = (#options * 32) + 8
					Tween(DropdownFrame, {Size = UDim2.new(1, 0, 0, 40 + contentHeight)}, 0.2)
					Tween(Arrow, {Rotation = 180}, 0.2)
					DropdownContent.Visible = true
				else
					Tween(DropdownFrame, {Size = UDim2.new(1, 0, 0, 40)}, 0.2)
					Tween(Arrow, {Rotation = 0}, 0.2)
					DropdownContent.Visible = false
				end
			end)
			
			local element = {
				Frame = DropdownFrame,
				SetSelected = function(newSelected)
					selected = newSelected
					SelectedLabel.Text = tostring(selected)
					callback(selected)
				end,
				GetSelected = function() return selected end
			}
			
			table.insert(tab.Elements, element)
			return element
		end)
		
		return tab
	end
	
