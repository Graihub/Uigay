					Parent = SliderFrame,
					Size = UDim2.new(1, -24, 0, 16),
					Position = UDim2.new(0, 12, 0, 28),
					BackgroundTransparency = 1,
					Text = description,
					Font = Settings.Font,
					TextSize = 12,
					TextColor3 = GetThemeColor("TextSecondary"),
					TextXAlignment = Enum.TextXAlignment.Left
				})
			end
			
			local SliderBar = Create("Frame", {
				Parent = SliderFrame,
				Size = UDim2.new(1, -40, 0, 4),
				Position = UDim2.new(0, 20, 0, 46),
				BackgroundColor3 = GetThemeColor("Secondary"),
				BorderSizePixel = 0
			})
			
			CreateCorner(SliderBar, 2)
			
			local SliderFill = Create("Frame", {
				Parent = SliderBar,
				Size = UDim2.new((default - min) / (max - min), 0, 1, 0),
				BackgroundColor3 = Settings.AccentColor,
				BorderSizePixel = 0
			})
			
			CreateCorner(SliderFill, 2)
			
			local SliderKnob = Create("Frame", {
				Parent = SliderBar,
				Size = UDim2.new(0, 16, 0, 16),
				Position = UDim2.new(SliderFill.Size.X.Scale, -8, 0.5, -8),
				BackgroundColor3 = Color3.fromRGB(255, 255, 255),
				BorderSizePixel = 0
			})
			
			CreateCorner(SliderKnob, 8)
			CreateStroke(SliderKnob, Settings.AccentColor, 2)
			
			local dragging = false
			
			local function UpdateSlider(input)
				local pos = input.Position.X - SliderBar.AbsolutePosition.X
				local percent = math.clamp(pos / SliderBar.AbsoluteSize.X, 0, 1)
				value = min + (max - min) * percent
				
				SliderFill.Size = UDim2.new(percent, 0, 1, 0)
				SliderKnob.Position = UDim2.new(percent, -8, 0.5, -8)
				ValueLabel.Text = tostring(math.floor(value * 100) / 100)
				callback(value)
			end
			
			SliderKnob.InputBegan:Connect(function(input)
				if input.UserInputType == Enum.UserInputType.MouseButton1 then
					dragging = true
				end
			end)
			
			SliderKnob.InputEnded:Connect(function(input)
				if input.UserInputType == Enum.UserInputType.MouseButton1 then
					dragging = false
				end
			end)
			
			UserInputService.InputChanged:Connect(function(input)
				if dragging and (input.UserInputType == Enum.UserInputType.MouseMovement or input.UserInputType == Enum.UserInputType.Touch) then
					UpdateSlider(input)
				end
			end)
			
			local element = {
				Frame = SliderFrame,
				SetValue = function(newValue)
					value = math.clamp(newValue, min, max)
					local percent = (value - min) / (max - min)
					SliderFill.Size = UDim2.new(percent, 0, 1, 0)
					SliderKnob.Position = UDim2.new(percent, -8, 0.5, -8)
					ValueLabel.Text = tostring(math.floor(value * 100) / 100)
					callback(value)
				end,
				GetValue = function() return value end
			}
			
			table.insert(tab.Elements, element)
			return element
		end)
		
		function tab:CreateDropdown(name, options, default, callback, description)
			options = options or {}
			default = default or options[1]
			callback = callback or function() end
			
			local selected = default
			local expanded = false
			
			local DropdownFrame = Create("Frame", {
				Name = name.."Dropdown",
				Parent = TabPage,
				Size = UDim2.new(1, 0, 0, 40),
				AutomaticSize = Enum.AutomaticSize.Y,
